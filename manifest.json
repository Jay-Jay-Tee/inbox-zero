{
  "manifest_version": 3,
  "name": "InboxZero AI",
  "version": "1.1",
  "description": "Intelligent Gmail productivity assistant",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/gmail-parser.js",
        "content/ui-injector.js"
      ],
      "matches": [
        "https://mail.google.com/*"
      ]
    }
  ]
}